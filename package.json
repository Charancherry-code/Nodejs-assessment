{
  "name": "github-profile-analyzer",
  "version": "1.0.0",
  "description": "Backend service that analyzes a GitHub user profile via the public GitHub API and stores useful insights in MySQL.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:init": "node scripts/initDb.js"
  },
  "keywords": [
    "github",
    "profile",
    "analyzer",
    "express",
    "mysql"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "1.7.7",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.21.0",
    "express-rate-limit": "7.4.0",
    "helmet": "7.1.0",
    "morgan": "1.10.0",
    "mysql2": "3.11.3"
  },
  "devDependencies": {
    "nodemon": "3.1.7"
  },
  "engines": {
    "node": ">=18"
  }
}
