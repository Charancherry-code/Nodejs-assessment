# Server
PORT=3000
NODE_ENV=development

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=github_analyzer
# Set to "true" when connecting to managed MySQL (TiDB Cloud, Aiven, etc.)
DB_SSL=false

# GitHub API (optional but recommended to avoid low unauthenticated rate limits)
# Create a Personal Access Token at https://github.com/settings/tokens (no scopes needed for public data)
GITHUB_TOKEN=
