{
  "info": {
    "name": "GitHub Profile Analyzer",
    "description": "Collection for the GitHub Profile Analyzer backend (Node.js + Express + MySQL).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://nodejs-assessment-production.up.railway.app" },
    { "key": "username", "value": "octocat" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
      }
    },
    {
      "name": "Analyze Profile",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/profiles/analyze",
          "host": ["{{baseUrl}}"],
          "path": ["api", "profiles", "analyze"]
        }
      }
    },
    {
      "name": "List Profiles",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profiles?limit=50&offset=0&sort=last_analyzed_at&order=DESC",
          "host": ["{{baseUrl}}"],
          "path": ["api", "profiles"],
          "query": [
            { "key": "limit", "value": "50" },
            { "key": "offset", "value": "0" },
            { "key": "sort", "value": "last_analyzed_at" },
            { "key": "order", "value": "DESC" }
          ]
        }
      }
    },
    {
      "name": "Get Profile By Username",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profiles/{{username}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "profiles", "{{username}}"]
        }
      }
    },
    {
      "name": "Refresh Profile",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profiles/{{username}}/refresh",
          "host": ["{{baseUrl}}"],
          "path": ["api", "profiles", "{{username}}", "refresh"]
        }
      }
    },
    {
      "name": "Delete Profile",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profiles/{{username}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "profiles", "{{username}}"]
        }
      }
    }
  ]
}
